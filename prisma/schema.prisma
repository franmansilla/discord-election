generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  isAdmin       Boolean      @default(false)
  memberships   ListMember[]
  votes         Vote[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Election {
  id              String         @id @default(cuid())
  title           String
  description     String?
  startDate       DateTime
  endDate         DateTime
  resultsRevealed Boolean        @default(false)
  status          ElectionStatus @default(DRAFT)
  voteMode        VoteMode       @default(FULL_LIST)
  lists           CandidateList[]
  votes           Vote[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model CandidateList {
  id         String       @id @default(cuid())
  electionId String
  election   Election     @relation(fields: [electionId], references: [id], onDelete: Cascade)
  name       String
  status     ListStatus   @default(OPEN)
  members    ListMember[]
  votes      Vote[]
  createdAt  DateTime     @default(now())
}

model ListMember {
  id         String        @id @default(cuid())
  listId     String
  list       CandidateList @relation(fields: [listId], references: [id], onDelete: Cascade)
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  position       Int
  role           String?
  proposal       String?
  campaignImage  String?
  votes          Vote[]
  createdAt  DateTime      @default(now())

  @@unique([listId, position])
  @@unique([listId, userId])
}

model Vote {
  id         String         @id @default(cuid())
  electionId String
  election   Election       @relation(fields: [electionId], references: [id])
  voterId    String
  voter      User           @relation(fields: [voterId], references: [id])
  position   Int            @default(0)
  listId     String?
  list       CandidateList? @relation(fields: [listId], references: [id])
  memberId   String?
  member     ListMember?    @relation(fields: [memberId], references: [id])
  votedAt    DateTime       @default(now())

  @@unique([electionId, voterId, position])
}

enum ElectionStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum VoteMode {
  FULL_LIST
  SPLIT
}

enum ListStatus {
  OPEN
  COMPLETE
}
